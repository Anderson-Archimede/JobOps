{
  "version": 2,
  "buildCommand": "cd orchestrator && npm run vercel-build",
  "outputDirectory": "orchestrator/dist/client",
  "installCommand": "npm ci --workspace orchestrator --workspace shared --include-workspace-root",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://jobops.onrender.com/api/:path*"
    },
    {
      "source": "/pdfs/:path*",
      "destination": "https://jobops.onrender.com/pdfs/:path*"
    },
    {
      "source": "/((?!api)(?!pdfs)(?!assets)(?!favicon)(?!_next).*)",
      "destination": "/index.html"
    }
  ]
}
