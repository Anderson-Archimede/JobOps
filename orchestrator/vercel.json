{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://jobops.onrender.com/api/:path*"
    },
    {
      "source": "/pdfs/:path*",
      "destination": "https://jobops.onrender.com/pdfs/:path*"
    },
    {
      "source": "/((?!api)(?!pdfs)(?!assets)(?!favicon)(?!_next).*)",
      "destination": "/index.html"
    }
  ]
}
